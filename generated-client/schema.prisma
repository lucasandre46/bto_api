generator client {
  provider = "prisma-client-js"
  output   = "../generated-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  telefone  String
  favoritos String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // Tabela no banco continua sendo 'users'
}
